---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import { getCollection } from 'astro:content';

const allWriteups = await getCollection('writeups');
const allNotes = await getCollection('notes');

const allPosts = [...allWriteups, ...allNotes].filter(p => !p?.data?.draft);

// Filter by writeups collection
const writeupPosts = allPosts.filter(post => {
  return post.collection === 'writeups';
}).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const nodeCount = writeupPosts.length;
---

<BaseLayout title="Writeups">
  <div class="px-8 py-8 max-w-6xl mx-auto h-full flex flex-col">
    <!-- Search Bar -->
    <div class="mb-12">
      <SearchBar />
    </div>

    <!-- Vault Header -->
    <div class="flex items-center justify-between mb-8 pb-4 border-b border-border-subtle">
      <div class="flex items-center gap-3">
        <div class="text-[#4edea3]">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <h1 class="text-3xl font-bold text-text-primary">Writeups</h1>
      </div>
      <div class="text-xs font-mono text-text-muted">
        {nodeCount} Nodes
      </div>
    </div>

    <!-- Notes Grid -->
    <div class="grid grid-cols-1 gap-4 pb-12">
      {writeupPosts.map(post => {
        return (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
            category={post.data.category}
            collection="writeups"
          />
        );
      })}
      
      {writeupPosts.length === 0 && (
        <div class="col-span-1 md:col-span-2 py-12 text-center text-text-muted border border-dashed border-border-subtle rounded-lg">
          No writeups found.
        </div>
      )}
    </div>
  </div>
</BaseLayout>
