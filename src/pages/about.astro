---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  { name: 'Web Security', icon: '🌐' },
  { name: 'Binary Exploitation', icon: '⚙️' },
  { name: 'Cryptography', icon: '🔐' },
  { name: 'Forensics', icon: '🔍' },
  { name: 'Reverse Engineering', icon: '🔧' },
];

const techStack = [
  { name: 'Astro', url: 'https://astro.build' },
  { name: 'Tailwind CSS', url: 'https://tailwindcss.com' },
  { name: 'GitHub Pages', url: 'https://pages.github.com' },
];
---

<BaseLayout title="About">
  <section class="px-4 py-12 sm:py-16">
    <div class="max-w-3xl mx-auto">
      <!-- Profile Section -->
      <div class="text-center mb-16 animate-section">
        <!-- Avatar -->
        <div class="relative inline-block mb-6">
          <div class="w-28 h-28 rounded-full bg-gradient-to-br from-[#00dbe7] to-[#4edea3] p-[2px]">
            <div class="w-full h-full rounded-full bg-bg-primary flex items-center justify-center">
              <span class="text-4xl font-bold font-[family-name:var(--font-heading)] bg-gradient-to-br from-[#00dbe7] to-[#4edea3] bg-clip-text text-transparent">
                S
              </span>
            </div>
          </div>
          <!-- Online indicator -->
          <div class="absolute bottom-1 right-1 w-5 h-5 rounded-full bg-bg-primary flex items-center justify-center">
            <div class="w-3 h-3 rounded-full bg-[#4edea3] animate-pulse"></div>
          </div>
        </div>

        <!-- Name & Bio -->
        <h1 class="text-4xl sm:text-5xl font-bold font-[family-name:var(--font-heading)] text-text-primary mb-2">
          Sandy
        </h1>
        <div class="h-1 w-16 bg-gradient-to-r from-[#00dbe7] to-[#4edea3] rounded-full mx-auto mb-4"></div>
        <p class="text-lg text-text-muted max-w-lg mx-auto leading-relaxed">
          CTF player and security enthusiast — learning, breaking things, and documenting the journey one challenge at a time.
        </p>
      </div>

      <!-- Skills Section -->
      <div class="mb-16 animate-section" style="animation-delay: 150ms">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-[#00dbe7]/20 to-[#4edea3]/20 flex items-center justify-center border border-border/30">
            <svg class="w-4 h-4 text-[#00dbe7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-text-primary">
            Skills & Interests
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {skills.map((skill, index) => (
            <div
              class="skill-card group flex items-center gap-3 px-4 py-3.5 rounded-xl border border-border/50 bg-bg-secondary/40 backdrop-blur-sm transition-all duration-300 hover:border-[#00dbe7]/30 hover:bg-bg-secondary/70 hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(0,219,231,0.08)]"
              style={`animation-delay: ${index * 60}ms`}
            >
              <span class="text-xl">{skill.icon}</span>
              <span class="text-text-primary font-medium">{skill.name}</span>
              <div class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="w-1.5 h-1.5 rounded-full bg-[#00dbe7]"></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Links Section -->
      <div class="mb-16 animate-section" style="animation-delay: 300ms">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-[#00dbe7]/20 to-[#4edea3]/20 flex items-center justify-center border border-border/30">
            <svg class="w-4 h-4 text-[#4edea3]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-text-primary">
            Links
          </h2>
        </div>

        <a
          href="https://github.com/b-sandyawan"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 px-5 py-4 rounded-xl border border-border/50 bg-bg-secondary/40 backdrop-blur-sm transition-all duration-300 hover:border-[#00dbe7]/30 hover:bg-bg-secondary/70 hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(0,219,231,0.08)]"
        >
          <div class="w-10 h-10 rounded-lg bg-bg-primary border border-border/30 flex items-center justify-center group-hover:border-[#00dbe7]/30 transition-colors duration-300">
            <svg class="w-5 h-5 text-text-primary" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div class="flex-1">
            <div class="text-text-primary font-medium group-hover:text-[#00dbe7] transition-colors duration-300">GitHub</div>
            <div class="text-sm text-text-muted font-mono">b-sandyawan</div>
          </div>
          <svg class="w-4 h-4 text-[#3a494b] group-hover:text-[#00dbe7] transition-all duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>

      <!-- Tech Stack Section -->
      <div class="animate-section" style="animation-delay: 450ms">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-[#00dbe7]/20 to-[#4edea3]/20 flex items-center justify-center border border-border/30">
            <svg class="w-4 h-4 text-[#00dbe7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] text-text-primary">
            Built With
          </h2>
        </div>

        <div class="px-5 py-5 rounded-xl border border-border/50 bg-bg-secondary/40 backdrop-blur-sm">
          <p class="text-text-muted leading-relaxed mb-4">
            This blog is built with modern web technologies, focused on performance, accessibility, and developer experience.
          </p>
          <div class="flex flex-wrap gap-2">
            {techStack.map(tech => (
              <a
                href={tech.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-border/40 bg-bg-primary/60 text-sm text-text-primary font-mono transition-all duration-300 hover:border-[#00dbe7]/30 hover:text-[#00dbe7]"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-[#4edea3]"></span>
                {tech.name}
              </a>
            ))}
          </div>
        </div>

        <!-- Terminal-style footer -->
        <div class="mt-8 px-4 py-3 rounded-lg bg-bg-primary/80 border border-border/30 font-mono text-sm">
          <span class="text-[#4edea3]">$</span>
          <span class="text-text-muted ml-2">echo</span>
          <span class="text-[#00dbe7] ml-1">"Thanks for visiting! Happy hacking 🚀"</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .animate-section {
    animation: section-in 0.6s ease-out forwards;
    opacity: 0;
  }

  @keyframes section-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
