---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import { getCollection } from 'astro:content';

const allWriteups = await getCollection('writeups');
const allNotes = await getCollection('notes');


const allPosts = [...allWriteups, ...allNotes, ].filter(p => !p?.data?.draft);

// Filter by notes collection OR tag 'note'/'notes'
const notePosts = allPosts.filter(post => {
  const isNoteCollection = post.collection === 'notes';
  const hasNoteTag = post.data.tags?.some(tag => tag.toLowerCase() === 'note' || tag.toLowerCase() === 'notes');
  return isNoteCollection || hasNoteTag;
}).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const nodeCount = notePosts.length;
---

<BaseLayout title="Notes">
  <div class="px-8 py-8 max-w-6xl mx-auto h-full flex flex-col">
    <!-- Search Bar -->
    <div class="mb-12">
      <SearchBar />
    </div>

    <!-- Vault Header -->
    <div class="flex items-center justify-between mb-8 pb-4 border-b border-border-subtle">
      <div class="flex items-center gap-3">
        <div class="text-[#00dbe7]">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <h1 class="text-3xl font-bold text-text-primary">Notes</h1>
      </div>
      <div class="text-xs font-mono text-text-muted">
        {nodeCount} Nodes
      </div>
    </div>

    <!-- Notes Grid -->
    <div class="grid grid-cols-1 gap-4 pb-12">
      {notePosts.map(post => {
        const collectionName = post.collection || (allWriteups.find(w => w.id === post.id) ? 'writeups' : 'notes');
        
        return (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
            category={post.data.category}
            collection={collectionName as "writeups" | "notes" | "archives"}
          />
        );
      })}
      
      {notePosts.length === 0 && (
        <div class="col-span-1 md:col-span-2 py-12 text-center text-text-muted border border-dashed border-border-subtle rounded-lg">
          No notes found. Add notes to the notes folder or tag them with #notes.
        </div>
      )}
    </div>
  </div>
</BaseLayout>
