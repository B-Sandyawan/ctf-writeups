---
const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-border/40 bg-bg-primary">
  <!-- Top gradient accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00dbe7]/20 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Left: Copyright -->
      <div class="flex items-center gap-2 text-sm text-text-muted">
        <span class="text-text-muted/60">©</span>
        <span>{currentYear}</span>
        <a
          href="/"
          class="font-semibold bg-gradient-to-r from-[#00dbe7] to-[#4edea3] bg-clip-text text-transparent hover:opacity-80 transition-opacity duration-200"
        >
          CTF_JOURNEY
        </a>
      </div>

      <!-- Center: Built with -->
      <div class="flex items-center gap-1.5 text-sm text-text-muted/60">
        <span>Built with</span>
        <svg class="w-4 h-4 text-[#00dbe7]/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Astro & Tailwind</span>
      </div>

      <!-- Right: GitHub link -->
      <a
        href="https://github.com/b-sandyawan"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-2 text-sm text-text-muted transition-all duration-200 hover:text-[#00dbe7]"
        aria-label="GitHub profile"
      >
        <svg
          class="w-5 h-5 transition-transform duration-200 group-hover:scale-110"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          />
        </svg>
        <span class="hidden sm:inline">b-sandyawan</span>
      </a>
    </div>
  </div>
</footer>
