---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  return pathname === path || pathname.startsWith(path + '/');
};
---
<header class="h-14 border-b border-border-subtle flex items-center px-6 shrink-0 bg-bg-primary/95 backdrop-blur-sm sticky top-0 z-10">
  <!-- Main Tabs -->
  <nav class="flex h-full">
    <a href="/" class={`h-full flex items-center px-4 text-sm font-medium border-b-2 transition-colors ${isActive('/') && pathname === '/' ? 'text-[#00dbe7] border-[#00dbe7]' : 'text-text-muted border-transparent hover:text-text-primary hover:border-border'}`}>
      Home
    </a>
    <a href="/writeups" class={`h-full flex items-center px-4 text-sm font-medium border-b-2 transition-colors ${isActive('/writeups') ? 'text-[#00dbe7] border-[#00dbe7]' : 'text-text-muted border-transparent hover:text-text-primary hover:border-border'}`}>
      Writeups
    </a>
    <a href="/notes" class={`h-full flex items-center px-4 text-sm font-medium border-b-2 transition-colors ${isActive('/notes') ? 'text-[#00dbe7] border-[#00dbe7]' : 'text-text-muted border-transparent hover:text-text-primary hover:border-border'}`}>
      Notes
    </a>
  </nav>

  <div class="flex-1"></div>

  <!-- Right Actions -->
  <div class="flex items-center gap-4">
    <button onclick="window.openSearchModal && window.openSearchModal()" class="text-text-muted hover:text-text-primary transition-colors" title="Command Palette">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
    </button>
    <button class="text-text-muted hover:text-text-primary transition-colors" title="Settings">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    </button>
    <ThemeToggle />
  </div>
</header>
