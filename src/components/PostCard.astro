---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  category?: string;
  collection: "writeups" | "notes";
}

const { title, description, date, tags, slug, category, collection } = Astro.props;

// Format date to look like 2024-10-24 14:32Z
const formattedDate = new Date(date).toISOString().replace('T', ' ').substring(0, 16) + 'Z';

const postUrl = `/${collection}/${slug}/`;

// Determine top label based on category or collection
let labelIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
let labelText = 'NOTE';
let labelColor = 'text-[#00dbe7]';

if (collection === 'writeups') {
  labelIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>';
  labelText = 'WRITEUP';
  labelColor = 'text-[#4edea3]';
}

if (category && category.toLowerCase() === 'analysis') {
  labelText = 'ANALYSIS';
  labelColor = 'text-[#00dbe7]';
} else if (category && category.toLowerCase() === 'malware') {
  labelIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m17 5-10 14"/><path d="m5 5 10 14"/></svg>';
  labelText = 'MALWARE';
  labelColor = 'text-[#eab308]';
}
---

<a href={postUrl} class="block border border-border-subtle bg-bg-secondary/50 hover:bg-bg-secondary rounded-lg p-5 transition-colors group">
  <!-- Top Row -->
  <div class="flex justify-between items-center mb-4">
    <div class={`flex items-center gap-1.5 text-xs font-bold tracking-widest ${labelColor}`}>
      <Fragment set:html={labelIcon} />
      {labelText}
    </div>
    <div class="text-[10px] text-text-muted font-mono">
      {formattedDate}
    </div>
  </div>

  <!-- Title -->
  <h3 class="text-xl font-bold text-text-primary mb-3 group-hover:text-[#00dbe7] transition-colors leading-snug">
    {title}
  </h3>

  <!-- Description -->
  <p class="text-text-muted text-sm leading-relaxed mb-6 line-clamp-3">
    {description}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="px-2 py-1 text-[10px] bg-bg-tertiary border border-border-subtle text-text-muted rounded font-mono">
        #{tag}
      </span>
    ))}
  </div>
</a>
