---
// ThemeToggle - toggles .dark class on <html> with localStorage persistence
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  class="group relative flex items-center justify-center w-10 h-10 rounded-full border border-border bg-bg-secondary/60 backdrop-blur-sm transition-all duration-300 hover:border-[#00dbe7]/60 hover:bg-bg-secondary/80 hover:shadow-[0_0_12px_rgba(0,219,231,0.15)] cursor-pointer"
>
  <!-- Sun icon (shown in dark mode → click to go light) -->
  <svg
    id="icon-sun"
    class="absolute w-5 h-5 text-[#00dbe7] transition-all duration-500 ease-out transform scale-0 rotate-90 opacity-0"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>

  <!-- Moon icon (shown in light mode → click to go dark) -->
  <svg
    id="icon-moon"
    class="absolute w-5 h-5 text-text-primary transition-all duration-500 ease-out transform scale-0 -rotate-90 opacity-0"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  function initThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    const iconSun = document.getElementById("icon-sun");
    const iconMoon = document.getElementById("icon-moon");
    if (!btn || !iconSun || !iconMoon) return;

    function updateIcons() {
      const isDark = document.documentElement.classList.contains("dark");
      if (isDark) {
        // Dark mode: show sun icon (to switch to light)
        iconSun.classList.remove("scale-0", "rotate-90", "opacity-0");
        iconSun.classList.add("scale-100", "rotate-0", "opacity-100");
        iconMoon.classList.add("scale-0", "-rotate-90", "opacity-0");
        iconMoon.classList.remove("scale-100", "rotate-0", "opacity-100");
      } else {
        // Light mode: show moon icon (to switch to dark)
        iconMoon.classList.remove("scale-0", "-rotate-90", "opacity-0");
        iconMoon.classList.add("scale-100", "rotate-0", "opacity-100");
        iconSun.classList.add("scale-0", "rotate-90", "opacity-0");
        iconSun.classList.remove("scale-100", "rotate-0", "opacity-100");
      }
    }

    // Set initial state
    updateIcons();

    btn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateIcons();
    });
  }

  // Run on initial load and on Astro page transitions
  initThemeToggle();
  document.addEventListener("astro:after-swap", initThemeToggle);
</script>
